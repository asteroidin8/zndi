{
  "expo": {
    "name": "zndi",
    "slug": "zndi",
    "owner": "asteroidin8",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "zndi",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.asteroidin8.zndi",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "단식 진행, 루틴·할 일 알림을 보내기 위해 알림 권한이 필요합니다.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.asteroidin8.zndi",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#22C55E"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "GrassWidget",
              "label": "잔디",
              "description": "주간 잔디와 오늘 달성률",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "resizeMode": "none",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "ChecklistWidget",
              "label": "잔디 체크리스트",
              "description": "오늘의 루틴과 할일 체크",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "FastingWidget",
              "label": "단식 타이머",
              "description": "단식 진행 상태",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "resizeMode": "none",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f9e38d8d-3dce-48c9-a396-7522eb725121"
      }
    }
  }
}
